---
import { getCollection, render } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

const projectEntries = await getCollection('projects');
const projects = projectEntries.sort((a, b) => a.data.title.localeCompare(b.data.title));

const rendered = await Promise.all(
	projects.map(async (entry) => ({
		...entry,
		Content: (await render(entry)).Content,
	}))
);

const types = [...new Set(projects.map((w) => w.data.type))].sort();
const skills = [...new Set(projects.flatMap((w) => w.data.skills))].sort();
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Projects — ${SITE_TITLE}`} description="Projects by Liam Connors" />
		<style>
			main {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 3em 1em;
			}
			h1 {
				font-size: 2.2rem;
			}
			.controls {
				margin-bottom: 1.5rem;
			}
			.control-row {
				display: flex;
				gap: 0.5rem;
				margin-bottom: 0.75rem;
				flex-wrap: wrap;
				align-items: center;
			}

			.control-label {
				font-size: 0.85em;
				color: rgb(var(--gray));
				margin-right: 0.25rem;
			}
			.controls button {
				padding: 0.35em 0.7em;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 4px;
				background: white;
				color: rgb(var(--gray-dark));
				font-family: var(--font-atkinson);
				font-size: 0.85em;
				cursor: pointer;
				transition: 0.15s ease;
			}
			.controls button:hover {
				border-color: var(--accent);
				color: var(--accent);
			}
			.controls button.active {
				background: var(--accent);
				border-color: var(--accent);
				color: white;
			}
			.skill-filters {
				display: flex;
				gap: 0.35rem;
				flex-wrap: wrap;
			}
			.skill-filters button {
				padding: 0.25em 0.6em;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 20px;
				background: white;
				color: rgb(var(--gray-dark));
				font-family: var(--font-atkinson);
				font-size: 0.8em;
				cursor: pointer;
				transition: 0.15s ease;
			}
			.skill-filters button:hover {
				border-color: var(--accent);
				color: var(--accent);
			}
			.skill-filters button.active {
				background: var(--accent);
				border-color: var(--accent);
				color: white;
			}
			.group-header {
				font-size: 1.5em;
				color: rgb(var(--black));
				margin-top: 1.5rem;
				margin-bottom: 0.75rem;
				padding-bottom: 0.25rem;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.card {
				padding: 1rem;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 6px;
				margin-bottom: 0.75rem;
			}
			.card-header {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				gap: 1rem;
				margin-bottom: 0.25rem;
			}
			.card-title {
				margin: 0;
				font-size: 1.1em;
			}
			.card-company {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 0.85em;
			}
			.card-company::before {
				content: "@ ";
			}
			.card-desc {
				margin: 0.4rem 0 0;
				color: rgb(var(--gray));
				font-size: 0.95em;
			}
			.card-body {
				margin: 0.5rem 0 0;
				font-size: 0.95em;
				line-height: 1.6;
			}
			.card-body :global(p) {
				margin: 0.3rem 0;
			}
			.card-body :global(ul),
			.card-body :global(ol) {
				margin: 0.3rem 0;
				padding-left: 1.2em;
			}
			.card-links {
				margin: 0.5rem 0 0;
				padding: 0;
				list-style: none;
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
			}
			.card-links a {
				display: inline-block;
				padding: 0.2em 0.6em;
				border: 1px solid var(--accent);
				border-radius: 4px;
				color: var(--accent);
				font-size: 0.82em;
				text-decoration: none;
				transition: 0.15s ease;
			}
			.card-links a:hover {
				background: var(--accent);
				color: white;
			}
			.skills {
				display: flex;
				gap: 0.35rem;
				flex-wrap: wrap;
				margin-top: 0.5rem;
			}
			.skill-pill {
				display: inline-block;
				padding: 0.15em 0.5em;
				border-radius: 3px;
				background: rgb(var(--gray-light));
				color: rgb(var(--gray-dark));
				font-size: 0.78em;
				border: 1px solid rgb(var(--gray-light));
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>Projects</h1>
			<p>Projects I've built and worked on in a personal and professional context.</p>

			<div class="controls">
				<div class="control-row">
					<span class="control-label">Filter by skill:</span>
					<div class="skill-filters">
						<button class="active" data-skill="all">All</button>
						{skills.map((skill) => (
							<button data-skill={skill}>{skill}</button>
						))}
					</div>
				</div>
			</div>

			<!-- By Type view -->
			<div class="view active" id="view-type">
				{types.map((type) => {
					const items = rendered.filter((w) => w.data.type === type);
					return items.length > 0 ? (
						<>
							<h2 class="group-header">{type}</h2>
							{items.map((item) => (
								<div class="card">
									<div class="card-header">
										<h3 class="card-title">{item.data.title}</h3>
										{item.data.company && (
											<p class="card-company">{item.data.company}</p>
										)}
									</div>
									<p class="card-desc">{item.data.description}</p>
									<div class="card-body">
										<item.Content />
									</div>
									{item.data.links && item.data.links.length > 0 && (
										<ul class="card-links">
{item.data.links.map((link) => (
    <li><a href={link.url} target="_blank">{link.label}</a></li>
))}
										</ul>
									)}
									<div class="skills">
										{item.data.skills.map((skill) => (
											<span class="skill-pill">{skill}</span>
										))}
									</div>
								</div>
							))}
						</>
					) : null;
				})}
			</div>
		</main>
		<Footer />
		<script>
			const skillButtons = document.querySelectorAll('[data-skill]');
			const viewType = document.getElementById('view-type');
			let currentSkill = 'all';

			function applyFilters() {
				const cards = viewType.querySelectorAll('.card');

				cards.forEach((card) => {
					if (currentSkill === 'all') {
						card.style.display = '';
					} else {
						const skills = Array.from(card.querySelectorAll('.skill-pill')).map((p) => p.textContent);
						card.style.display = skills.includes(currentSkill) ? '' : 'none';
					}
				});

				viewType.querySelectorAll('.group-header').forEach((header) => {
					let next = header.nextElementSibling;
					let hasVisible = false;
					while (next && !next.classList.contains('group-header')) {
						if (next.classList.contains('card') && next.style.display !== 'none') {
							hasVisible = true;
						}
						next = next.nextElementSibling;
					}
					header.style.display = hasVisible ? '' : 'none';
				});
			}

			skillButtons.forEach((button) => {
				button.addEventListener('click', () => {
					currentSkill = button.getAttribute('data-skill') || 'all';
					skillButtons.forEach((b) => b.classList.remove('active'));
					button.classList.add('active');
					applyFilters();
				});
			});
		</script>
	</body>
</html>